# ==============================================================
# AmIFree — local development environment variables
# ==============================================================
# Copy this file to `.env.local` and fill in real values. Never
# commit `.env.local` or any file containing real secrets.
#
# See docs/phases/22-canonical-beta-foundation.md
# §Environment and secrets plan for the full spec.
# ==============================================================

# ---- App / runtime ----
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_ENV=local
# Comma-separated list of owner email addresses allowed to sign in.
# Phase 22 is owner-only: no public signup, no self-serve invites.
APP_ALLOWED_EMAILS=owner@example.com

# ---- Supabase ----
# From https://supabase.com/dashboard/project/<project>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PROJECT_ID=
# From https://supabase.com/dashboard/project/<project>/settings/database
# Prefer the pooled connection string (port 6543) for the app.
DATABASE_URL=postgres://postgres:password@db.host:6543/postgres

# ---- Graphile Worker ----
# Can point at the same DATABASE as the app for MVP; a separate DB is
# recommended once job volume grows.
GRAPHILE_WORKER_DATABASE_URL=postgres://postgres:password@db.host:6543/postgres
GRAPHILE_WORKER_SCHEMA=graphile_worker
WORKER_CONCURRENCY=5

# ---- OpenAI ----
# Optional in Phase 22 foundation; required for Phase 23+ extraction flows.
OPENAI_API_KEY=

# ---- Observability ----
# Optional in local; required for preview and private-beta-production.
ERROR_TRACKING_DSN=
LOG_DRAIN_URL=
DEPLOYMENT_LABEL=local
